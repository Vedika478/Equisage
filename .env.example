# EquiSage — Environment Variables Example

# ============================================================
# REQUIRED
# ============================================================

# Groq API key (get from https://console.groq.com)
# Used by all LLM agents via LiteLLM (llama-3.3-70b-versatile) to run on a free-tier key
GROQ_API_KEY=your_groq_api_key_here

# ============================================================
# OPTIONAL
# ============================================================

# NewsAPI key (https://newsapi.org — free tier available)
# If not set, yfinance's built-in news feed is used as primary source.
# If yfinance also returns no news, a clearly-labelled mock response
# is used automatically so the pipeline still runs end-to-end.
# NEWS_API_KEY=your_newsapi_key_here
