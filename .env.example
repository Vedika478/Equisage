# EquiSage — Environment Variables

# ============================================================
# REQUIRED
# ============================================================

# Google Gemini API key (get from https://aistudio.google.com)
# Used by all LLM agents (FundamentalsAgent, TechnicalAgent, etc.)
GOOGLE_API_KEY=your_gemini_api_key_here

# Alternative key name (google-adk also accepts GEMINI_API_KEY)
# GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# OPTIONAL
# ============================================================

# NewsAPI key (https://newsapi.org — free tier available)
# If not set, yfinance's built-in news feed is used as primary source.
# If yfinance also returns no news, a clearly-labelled mock response
# is used automatically so the pipeline still runs end-to-end.
# NEWS_API_KEY=your_newsapi_key_here

# ============================================================
# ADK MODEL CONFIGURATION (optional — defaults shown)
# ============================================================

# Gemini model to use for all agents (flash is faster and cheaper)
# ADK_MODEL=gemini-2.0-flash
# ADK_MODEL=gemini-1.5-pro  # Slower but more capable for complex analysis
